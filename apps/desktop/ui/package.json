{
  "name": "vigil-desktop-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Vigil Desktop UI (I08b) — Vue 3 + Vite + TS + Naive UI + Tailwind",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
