{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vigil Desktop",
  "version": "0.0.1",
  "identifier": "local.vigil.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "./ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vigil Desktop — local control plane for AI agents",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "rpm", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://vigils.ai/desktop-updates/{{target}}-{{arch}}/{{current_version}}.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCNEIyNDdEQTc3Q0VBQzUKUldURjZueW5mU1JMVy8vSi9LNGluUzhSZG92Q0orTWh3dGZHNXhVSjRzSksvc2lsVUI5RThEM2MK"
    }
  }
}
